# ─────────────────────────────────────────────────────────────────────────────
# Broadcast — environment configuration
# Copy to .env and fill in what you have. Everything is optional: the platform
# runs fully in "simulated" mode when keys are absent, and switches to live
# behavior automatically when credentials are present.
# ─────────────────────────────────────────────────────────────────────────────

# Database (SQLite by default — no setup required)
DATABASE_URL="file:./dev.db"

# ── AI provider (used by the AI CMO + all content-generating agents) ──────────
# Provide ONE of the following. If neither is set, a deterministic local
# generator produces realistic content so the platform still works offline.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── X / Twitter posting (X Influencer Agent + tweet publishing) ───────────────
# Create an app at https://developer.x.com with Read+Write permissions.
# When these are set, the platform publishes real tweets; otherwise posts are
# stored in a simulated outbox and marked "published (simulated)".
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Optional OAuth2 bearer for read endpoints
X_BEARER_TOKEN=

# ── Google PageSpeed Insights (Lighthouse scores + Core Web Vitals) ───────────
# Optional. Without a key the public endpoint is used (rate limited).
PAGESPEED_API_KEY=

# ── Google Analytics / Search Console (OAuth) ─────────────────────────────────
# Optional. Connect flow records metadata; live metrics require these.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Reddit (Reddit Agent opportunity discovery) ───────────────────────────────
# Optional. Without these the public read-only JSON API is used.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Web search (competitor discovery + keyword/SERP data) ─────────────────────
# Optional, SerpAPI-compatible key. Without it, discovery uses DuckDuckGo's
# public HTML endpoint, so competitor discovery still works with zero keys.
SEARCH_API_KEY=

# Cron secret for the scheduled scan endpoint (any random string)
CRON_SECRET=dev-secret
